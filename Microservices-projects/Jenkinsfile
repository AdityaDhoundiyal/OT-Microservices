@Library('jenkins-shared-library@master') _

import org.example.NotificationManager

// ═══════════════════════════════════════════════════════════════
//  COMPLETE TESTING + MULTI-ENV DEPLOYMENT PIPELINE
//  Unit → Coverage → Parallel(Integration + Lint) → E2E
//  → Build & Load Docker Image (Minikube)
//  → Deploy Dev (auto) → Approval → Deploy Staging
//  → Approval → Blue-Green Prod → Health Check → Rollback
// ═══════════════════════════════════════════════════════════════

pipeline {
    agent any

    parameters {
        choice(
            name: 'SERVICE',
            choices: ['attendance', 'employee', 'salary', 'frontend', 'notification'],
            description: 'Microservice to test and deploy'
        )
        string(
            name: 'VERSION',
            defaultValue: '1.0.0',
            description: 'Version under test/deploy (semver e.g. 1.0.0)'
        )
        choice(
            name: 'TEST_SCOPE',
            choices: ['all', 'unit', 'integration', 'e2e'],
            description: 'Which tests to run'
        )
        choice(
            name: 'ENVIRONMENT',
            choices: ['staging', 'dev', 'prod'],
            description: 'Target environment for E2E tests and deployment'
        )
        string(
            name: 'RECIPIENTS',
            defaultValue: 'YOUR_EMAIL@gmail.com',
            description: 'Email recipients (comma separated)'
        )
        booleanParam(
            name: 'FAIL_ON_COVERAGE',
            defaultValue: true,
            description: 'Fail build if coverage below threshold?'
        )
        booleanParam(
            name: 'RUN_DEPLOYMENT',
            defaultValue: false,
            description: 'Run deployment stages after tests?'
        )
        string(
            name: 'STAGING_APPROVAL_TIMEOUT',
            defaultValue: '30',
            description: 'Minutes to wait for Staging manual approval'
        )
        string(
            name: 'PROD_APPROVAL_TIMEOUT',
            defaultValue: '30',
            description: 'Minutes to wait for Prod Blue-Green manual approval'
        )
    }

    environment {
    SERVICE       = "${params.SERVICE}"
    VERSION       = "${params.VERSION}"
    ENVIRONMENT   = "${params.ENVIRONMENT}"
    COVERAGE_MIN  = '60'
    REPORT_DIR    = 'test-reports'
    COVERAGE_DIR  = 'coverage-reports'
    JUNIT_PATTERN = "${REPORT_DIR}/**/*.xml"
    KUBECONFIG    = '/var/lib/jenkins/.kube/config'
    SLACK_CHANNEL = '#jenkins-notifications'
    SLACK_CRED_ID = 'slackaditya'
    K8S_DEV       = 'Microservices-projects/kubernetes/dev/attendance-k8s.yaml'
    K8S_STAGING   = 'Microservices-projects/kubernetes/staging/attendance-bluegree.yaml'
    K8S_PROD      = 'Microservices-projects/kubernetes/prod/attendance-k8s.yaml'
    HEALTH_CHECK_RETRIES  = '10'
    HEALTH_CHECK_INTERVAL = '10'
    HEALTH_PORT           = '8081'
    // ── Fix: tell minikube where its home is for jenkins user ──
    MINIKUBE_HOME = '/var/lib/jenkins/.minikube'
    HOME          = '/var/lib/jenkins'
}

    stages {

        // ── STAGE 1: SETUP ──────────────────────────────────────
        stage('Setup') {
            steps {
                script {
                    echo "═══════════════════════════════════════"
                    echo " TEST PIPELINE: ${SERVICE} v${VERSION}"
                    echo " Scope      : ${params.TEST_SCOPE}"
                    echo " Environment: ${ENVIRONMENT}"
                    echo "═══════════════════════════════════════"

                    def notifier = new NotificationManager(this)
                    def details  = getBuildDetails(this)
                    notifier.notifyAll('STARTED', details)

                    sh """
                        mkdir -p ${REPORT_DIR}/unit
                        mkdir -p ${REPORT_DIR}/integration
                        mkdir -p ${REPORT_DIR}/e2e
                        mkdir -p ${REPORT_DIR}/lint
                        mkdir -p ${COVERAGE_DIR}
                    """
                }
            }
        }

        // ── STAGE 2: UNIT TESTS ─────────────────────────────────
        stage('Unit Tests') {
            when {
                expression { return params.TEST_SCOPE in ['all', 'unit'] }
            }
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh """
                        cd Microservices-projects/${SERVICE}
                        if [ -f requirements.txt ]; then
                            pip3 install -r requirements.txt pytest pytest-cov pytest-html -q
                            python3 -m pytest \
                                --junitxml=../../${REPORT_DIR}/unit/unit-results.xml \
                                --cov=. \
                                --cov-report=xml:../../${COVERAGE_DIR}/coverage.xml \
                                --cov-report=html:../../${COVERAGE_DIR}/html \
                                --cov-report=term-missing \
                                --cov-fail-under=${COVERAGE_MIN} \
                                -v test_*.py \
                                2>&1 | tee ../../${REPORT_DIR}/unit/unit.log
                        elif [ -f package.json ]; then
                            npm install
                            npm test -- \
                                --reporter junit \
                                --reporter-options output=../../${REPORT_DIR}/unit/unit-results.xml \
                                2>&1 | tee ../../${REPORT_DIR}/unit/unit.log
                        elif [ -f pom.xml ]; then
                            mvn test \
                                -Dsurefire.reportsDirectory=../../${REPORT_DIR}/unit \
                                jacoco:report \
                                2>&1 | tee ../../${REPORT_DIR}/unit/unit.log
                        else
                            echo "No test framework detected — skipping"
                        fi
                    """
                }
            }
            post {
                always {
                    junit testResults: "${REPORT_DIR}/unit/unit-results.xml",
                          allowEmptyResults: true
                    archiveArtifacts artifacts: "${REPORT_DIR}/unit/**",
                                     allowEmptyArchive: true
                }
            }
        }

        // ── STAGE 3: COVERAGE CHECK ─────────────────────────────
        stage('Coverage Check') {
            when {
                expression { return params.TEST_SCOPE in ['all', 'unit'] }
            }
            steps {
                script {
                    echo "=== COVERAGE CHECK (min: ${COVERAGE_MIN}%) ==="
                }
                catchError(
                    buildResult: params.FAIL_ON_COVERAGE ? 'FAILURE' : 'UNSTABLE',
                    stageResult: 'FAILURE'
                ) {
                    sh """
                        if [ -f ${COVERAGE_DIR}/coverage.xml ]; then
                            COVERAGE=\$(python3 -c "
import xml.etree.ElementTree as ET
root = ET.parse('${COVERAGE_DIR}/coverage.xml').getroot()
rate = float(root.get('line-rate', 0)) * 100
print(f'{rate:.1f}')
")
                            echo "Coverage: \${COVERAGE}%"
                            echo "\${COVERAGE}" > ${COVERAGE_DIR}/coverage-percent.txt
                            python3 -c "
rate = float('\${COVERAGE}')
threshold = ${COVERAGE_MIN}
if rate < threshold:
    print(f'COVERAGE FAILED: {rate:.1f}% < {threshold}%')
    exit(1)
print(f'COVERAGE PASSED: {rate:.1f}% >= {threshold}%')
"
                        else
                            echo "No coverage.xml found — skipping coverage check"
                        fi
                    """
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${COVERAGE_DIR}/**",
                                     allowEmptyArchive: true
                }
            }
        }

        // ── STAGE 4: PARALLEL — INTEGRATION + LINT ─────────────
        stage('Parallel: Integration + Lint') {
            when {
                expression { return params.TEST_SCOPE in ['all', 'integration'] }
            }
            parallel {

                stage('Integration Tests') {
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh """
                                cd Microservices-projects/${SERVICE}
                                if [ -f requirements.txt ]; then
                                    python3 -m pytest \
                                        --junitxml=../../${REPORT_DIR}/integration/integration-results.xml \
                                        -v -m integration \
                                        test_*.py \
                                        2>&1 | tee ../../${REPORT_DIR}/integration/integration.log \
                                        || echo "Integration tests completed"
                                elif [ -f package.json ]; then
                                    npm run test:integration \
                                        2>&1 | tee ../../${REPORT_DIR}/integration/integration.log \
                                        || echo "Integration tests completed"
                                else
                                    echo "No integration tests found"
                                fi
                            """
                        }
                    }
                    post {
                        always {
                            junit testResults: "${REPORT_DIR}/integration/integration-results.xml",
                                  allowEmptyResults: true
                            archiveArtifacts artifacts: "${REPORT_DIR}/integration/**",
                                             allowEmptyArchive: true
                        }
                    }
                }

                stage('Lint & Static Analysis') {
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh """
                                cd Microservices-projects/${SERVICE}
                                if [ -f requirements.txt ]; then
                                    pip3 install flake8 pylint -q
                                    echo "--- flake8 ---"
                                    flake8 . \
                                        --max-line-length=120 \
                                        --exclude=.git,__pycache__,venv \
                                        > ../../${REPORT_DIR}/lint/flake8.log 2>&1 || true
                                    cat ../../${REPORT_DIR}/lint/flake8.log
                                    echo "--- pylint ---"
                                    pylint *.py \
                                        --fail-under=7.0 \
                                        > ../../${REPORT_DIR}/lint/pylint.log 2>&1 \
                                        || echo "Pylint score below threshold"
                                    cat ../../${REPORT_DIR}/lint/pylint.log
                                elif [ -f package.json ]; then
                                    npm run lint \
                                        > ../../${REPORT_DIR}/lint/eslint.log 2>&1 || true
                                fi
                            """
                        }
                    }
                    post {
                        always {
                            archiveArtifacts artifacts: "${REPORT_DIR}/lint/**",
                                             allowEmptyArchive: true
                        }
                    }
                }

            }
        }

        // ── STAGE 5: E2E TESTS ──────────────────────────────────
        stage('E2E Tests') {
            when {
                expression { return params.TEST_SCOPE in ['all', 'e2e'] }
            }
            steps {
                sh """
                    mkdir -p ${REPORT_DIR}/e2e
                    case "${ENVIRONMENT}" in
                        dev)     ENVS="dev" ;;
                        staging) ENVS="staging" ;;
                        prod)    ENVS="staging prod" ;;
                        *)       ENVS="staging" ;;
                    esac
                    echo "E2E environments: \$ENVS"
                    TOTAL=0; PASSED=0; FAILED=0; XML_CASES=""
                    for ENV in \$ENVS; do
                        echo "=== E2E: ${SERVICE} in \$ENV ==="
                        POD=\$(kubectl get pods -n \$ENV \
                            -l app=${SERVICE},slot=blue \
                            -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || echo "")
                        if [ -z "\$POD" ]; then
                            POD=\$(kubectl get pods -n \$ENV \
                                -l app=${SERVICE},slot=green \
                                -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || echo "")
                        fi
                        if [ -z "\$POD" ]; then
                            TOTAL=\$((TOTAL+1)); FAILED=\$((FAILED+1))
                            XML_CASES="\$XML_CASES
  <testcase name='e2e_health_\$ENV' classname='e2e.\$ENV'>
    <failure message='No pod found'>No pod found for ${SERVICE} in \$ENV</failure>
  </testcase>"
                            continue
                        fi
                        echo "Pod: \$POD"
                        STATUS="000"
                        for i in 1 2 3 4 5; do
                            STATUS=\$(kubectl exec -n \$ENV \$POD \
                                -- curl -s -o /dev/null -w "%{http_code}" \
                                http://localhost:8081/${SERVICE}/healthz \
                                2>/dev/null || echo "000")
                            echo "Attempt \$i [\$ENV]: HTTP \$STATUS"
                            if [ "\$STATUS" = "200" ]; then break; fi
                            sleep 5
                        done
                        TOTAL=\$((TOTAL+1))
                        if [ "\$STATUS" = "200" ]; then
                            PASSED=\$((PASSED+1))
                            echo "E2E PASSED: \$ENV ✅"
                            XML_CASES="\$XML_CASES
  <testcase name='e2e_health_\$ENV' classname='e2e.\$ENV'/>"
                        else
                            FAILED=\$((FAILED+1))
                            echo "E2E FAILED: \$ENV ❌ (HTTP \$STATUS)"
                            XML_CASES="\$XML_CASES
  <testcase name='e2e_health_\$ENV' classname='e2e.\$ENV'>
    <failure message='HTTP \$STATUS'>Health check failed in \$ENV</failure>
  </testcase>"
                        fi
                    done
                    cat > ${REPORT_DIR}/e2e/e2e-results.xml << XMLEOF
<?xml version="1.0" encoding="UTF-8"?>
<testsuite name="E2E-${SERVICE}" tests="\$TOTAL" failures="\$FAILED" skipped="0">
\$XML_CASES
</testsuite>
XMLEOF
                    echo "E2E Summary → Total: \$TOTAL | Passed: \$PASSED | Failed: \$FAILED"
                    if [ "\$FAILED" -gt "0" ]; then exit 1; fi
                    echo "All E2E tests PASSED ✅"
                """
            }
            post {
                always {
                    junit testResults: "${REPORT_DIR}/e2e/e2e-results.xml",
                          allowEmptyResults: true
                    archiveArtifacts artifacts: "${REPORT_DIR}/e2e/**",
                                     allowEmptyArchive: true
                }
            }
        }

        // ── STAGE 6: GENERATE PDF REPORT ───────────────────────
        stage('Generate PDF Report') {
            steps {
                sh """
                    pip3 install fpdf2 -q
                    python3 << 'PYEOF'
from fpdf import FPDF
import xml.etree.ElementTree as ET
import os, datetime

class TestReport(FPDF):
    def header(self):
        self.set_font('Helvetica', 'B', 16)
        self.set_fill_color(41, 128, 185)
        self.set_text_color(255, 255, 255)
        self.cell(0, 12, 'Jenkins Test Report', new_x='LMARGIN', new_y='NEXT', fill=True, align='C')
        self.set_text_color(0, 0, 0)
        self.ln(4)
    def footer(self):
        self.set_y(-15)
        self.set_font('Helvetica', 'I', 8)
        self.set_text_color(128, 128, 128)
        self.cell(0, 10,
            f'Page {self.page_no()} | Generated: {datetime.datetime.now().strftime("%Y-%m-%d %H:%M")}',
            align='C')

def parse_junit(path):
    if not os.path.exists(path):
        return {'tests':0,'failures':0,'errors':0,'skipped':0,'cases':[]}
    try:
        root = ET.parse(path).getroot()
        suite = root if root.tag == 'testsuite' else (root.find('testsuite') or root)
        cases = []
        for tc in suite.findall('testcase'):
            st = 'PASS'
            if tc.find('failure') is not None: st = 'FAIL'
            elif tc.find('error') is not None: st = 'ERROR'
            elif tc.find('skipped') is not None: st = 'SKIP'
            cases.append({'name': tc.get('name','?'), 'status': st, 'time': tc.get('time','0')})
        return {
            'tests'   : int(suite.get('tests', len(cases))),
            'failures': int(suite.get('failures', 0)),
            'errors'  : int(suite.get('errors', 0)),
            'skipped' : int(suite.get('skipped', 0)),
            'cases'   : cases
        }
    except:
        return {'tests':0,'failures':0,'errors':0,'skipped':0,'cases':[]}

def get_coverage():
    f = '${COVERAGE_DIR}/coverage-percent.txt'
    try:
        return float(open(f).read().strip()) if os.path.exists(f) else None
    except:
        return None

unit = parse_junit('${REPORT_DIR}/unit/unit-results.xml')
intg = parse_junit('${REPORT_DIR}/integration/integration-results.xml')
e2e  = parse_junit('${REPORT_DIR}/e2e/e2e-results.xml')
cov  = get_coverage()
total_tests    = unit['tests'] + intg['tests'] + e2e['tests']
total_failures = unit['failures'] + intg['failures'] + e2e['failures']
total_passed   = total_tests - total_failures

pdf = TestReport()
pdf.set_auto_page_break(auto=True, margin=15)
pdf.add_page()
pdf.set_font('Helvetica', 'B', 13)
pdf.set_fill_color(236, 240, 241)
pdf.cell(0, 9, 'Build Information', new_x='LMARGIN', new_y='NEXT', fill=True)
pdf.ln(2)
for k, v in [
    ('Service',     '${SERVICE}'),
    ('Version',     '${VERSION}'),
    ('Environment', '${ENVIRONMENT}'),
    ('Build No.',   '${BUILD_NUMBER}'),
    ('Timestamp',   datetime.datetime.now().strftime('%Y-%m-%d %H:%M')),
    ('Test Scope',  '${params.TEST_SCOPE}'),
]:
    pdf.set_font('Helvetica', 'B', 10); pdf.cell(45, 7, k + ':')
    pdf.set_font('Helvetica', '', 10)
    pdf.cell(0, 7, str(v), new_x='LMARGIN', new_y='NEXT')
pdf.ln(4)
os.makedirs('${REPORT_DIR}', exist_ok=True)
pdf.output('${REPORT_DIR}/test-report.pdf')
print('PDF generated: ${REPORT_DIR}/test-report.pdf')
PYEOF
                """
            }
            post {
                always {
                    archiveArtifacts artifacts: "${REPORT_DIR}/test-report.pdf",
                                     allowEmptyArchive: true
                }
            }
        }

        // ── STAGE 7: PUBLISH REPORTS ────────────────────────────
        stage('Publish Reports') {
            steps {
                script {
                    echo "=== PUBLISHING ALL REPORTS TO JENKINS ==="
                    junit testResults: "${JUNIT_PATTERN}",
                          allowEmptyResults: true
                    echo "Reports published ✅"
                }
            }
        }

        // ════════════════════════════════════════════════════════
        //  DEPLOYMENT STAGES (gated by RUN_DEPLOYMENT=true)
        //  Uses YOUR existing YAML files — no new manifests needed
        //  Image built locally → loaded into Minikube → applied
        // ════════════════════════════════════════════════════════

        // ── STAGE 8: BUILD DOCKER IMAGE & LOAD INTO MINIKUBE ───
        stage('Build & Load Docker Image') {
            when {
                expression { return params.RUN_DEPLOYMENT == true }
            }
            steps {
                script {
                    // Image name always = SERVICE:VERSION (local, no registry)
                    env.DOCKER_IMAGE_RESOLVED = "${params.SERVICE}:${params.VERSION}"
                    echo "=== Image: ${env.DOCKER_IMAGE_RESOLVED} ==="
                }
                sh """
                    echo "--- Building Docker image on Jenkins daemon ---"
                    cd Microservices-projects/${params.SERVICE}
                    docker build -t ${env.DOCKER_IMAGE_RESOLVED} .
                    echo "Build complete ✅"

                    echo "--- Loading image into Minikube ---"
                    minikube image load ${env.DOCKER_IMAGE_RESOLVED}
                    echo "Loaded into Minikube ✅"

                    echo "--- Verifying image inside Minikube ---"
                    minikube image ls | grep "${params.SERVICE}" \
                        && echo "Image confirmed ✅" \
                        || echo "WARNING: image not found in minikube image ls"
                """
            }
        }

        // ── STAGE 9: DEPLOY TO DEV (Automatic) ─────────────────
        // Uses: Microservices-projects/kubernetes/dev/attendance-k8s.yaml
        // Blue-Green already defined in YAML — just update image + apply
        stage('Deploy to Dev') {
            when {
                expression { return params.RUN_DEPLOYMENT == true }
            }
            steps {
                script {
                    milestone(1)
                    echo "═══════════════════════════════════════"
                    echo " DEPLOYING ${SERVICE} v${VERSION} → DEV"
                    echo "═══════════════════════════════════════"
                    def notifier = new NotificationManager(this)
                    def details  = getBuildDetails(this)
                    details.changes = details.changes + " | Deploying to DEV 🚀"
                    notifier.notifyAll('STARTED', details)
                }
                sh """
                    echo "--- Detecting live slot in dev ---"
                    LIVE_SLOT=\$(kubectl get service attendance -n dev \
                        -o jsonpath='{.spec.selector.slot}' 2>/dev/null || echo 'blue')
                    NEW_SLOT=\$([ "\$LIVE_SLOT" = "blue" ] && echo "green" || echo "blue")
                    echo "Live: \$LIVE_SLOT → Deploying to: \$NEW_SLOT"

                    echo "--- Patching image in YAML for \$NEW_SLOT slot ---"
                    # Update image in the existing YAML and apply
                    sed "s|image: attendance:.*|image: ${env.DOCKER_IMAGE_RESOLVED}|g" \
                        ${K8S_DEV} | kubectl apply -f -

                    echo "--- Waiting for \$NEW_SLOT rollout ---"
                    kubectl rollout status deployment/attendance-\$NEW_SLOT \
                        -n dev --timeout=180s

                    echo "Dev rollout complete ✅"
                """
                script {
                    // Health check new slot
                    def newSlot = sh(
                        script: """LIVE=\$(kubectl get service attendance -n dev \
                            -o jsonpath='{.spec.selector.slot}' 2>/dev/null || echo 'blue')
                            [ "\$LIVE" = "blue" ] && echo "green" || echo "blue" """,
                        returnStdout: true
                    ).trim()

                    def devPod = sh(
                        script: """kubectl get pods -n dev \
                            -l app=attendance,slot=${newSlot} \
                            -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || echo ''""",
                        returnStdout: true
                    ).trim()

                    if (!devPod) {
                        sh "kubectl rollout undo deployment/attendance-${newSlot} -n dev || true"
                        error("Dev health check failed: no pod found in ${newSlot} slot")
                    }

                    def devHealthy = false
                    for (int i = 1; i <= env.HEALTH_CHECK_RETRIES.toInteger(); i++) {
                        def status = sh(
                            script: """kubectl exec -n dev ${devPod} \
                                -- curl -s -o /dev/null -w "%{http_code}" \
                                http://localhost:${env.HEALTH_PORT}/${SERVICE}/healthz \
                                2>/dev/null || echo '000'""",
                            returnStdout: true
                        ).trim()
                        echo "Dev health attempt ${i}/${env.HEALTH_CHECK_RETRIES}: HTTP ${status}"
                        if (status == '200') { devHealthy = true; break }
                        sleep(env.HEALTH_CHECK_INTERVAL.toInteger())
                    }

                    if (!devHealthy) {
                        sh """
                            kubectl rollout undo deployment/attendance-${newSlot} -n dev
                            kubectl rollout status deployment/attendance-${newSlot} \
                                -n dev --timeout=120s
                        """
                        def notifier = new NotificationManager(this)
                        def details  = getBuildDetails(this)
                        details.changes = details.changes + " | Dev ROLLED BACK ❌"
                        notifier.notifyAll('FAILURE', details)
                        error("Dev deployment rolled back — health check failed ❌")
                    }

                    // Cutover: switch service selector to new slot
                    sh """
                        kubectl patch service attendance -n dev \
                            -p '{"spec":{"selector":{"slot":"${newSlot}"}}}'
                        echo "Dev traffic switched to ${newSlot} ✅"
                    """

                    def notifier = new NotificationManager(this)
                    def details  = getBuildDetails(this)
                    details.changes = details.changes + " | Dev deploy SUCCESS ✅"
                    notifier.notifyAll('SUCCESS', details)
                }
            }
        }

        // ── STAGE 10: APPROVAL FOR STAGING ─────────────────────
        stage('Approval: Deploy to Staging') {
            when {
                expression { return params.RUN_DEPLOYMENT == true }
            }
            steps {
                script {
                    milestone(2)
                    def notifier = new NotificationManager(this)
                    def details  = getBuildDetails(this)
                    details.changes = details.changes + " | Waiting for STAGING approval ⏳"
                    notifier.notifyAll('UNSTABLE', details)
                    echo "Waiting for Staging approval (timeout: ${params.STAGING_APPROVAL_TIMEOUT}m)"
                }
                timeout(time: params.STAGING_APPROVAL_TIMEOUT.toInteger(), unit: 'MINUTES') {
                    input(
                        message: "Deploy ${params.SERVICE} v${params.VERSION} to STAGING?",
                        ok: 'Yes, Deploy to Staging',
                        submitter: 'admin,devops-team',
                        submitterParameter: 'STAGING_APPROVER'
                    )
                }
                script {
                    echo "Staging approved ✅  Approver: ${env.STAGING_APPROVER ?: 'unknown'}"
                }
            }
        }

        // ── STAGE 11: DEPLOY TO STAGING ─────────────────────────
        // Uses: Microservices-projects/kubernetes/staging/attendance-bluegree.yaml
        stage('Deploy to Staging') {
            when {
                expression { return params.RUN_DEPLOYMENT == true }
            }
            steps {
                script {
                    echo "════════════════════════════════════════════"
                    echo " DEPLOYING ${SERVICE} v${VERSION} → STAGING"
                    echo "════════════════════════════════════════════"
                    def notifier = new NotificationManager(this)
                    def details  = getBuildDetails(this)
                    details.changes = details.changes + " | Deploying to STAGING 🚀"
                    notifier.notifyAll('STARTED', details)
                }
                sh """
                    echo "--- Detecting live slot in staging ---"
                    LIVE_SLOT=\$(kubectl get service attendance -n staging \
                        -o jsonpath='{.spec.selector.slot}' 2>/dev/null || echo 'blue')
                    NEW_SLOT=\$([ "\$LIVE_SLOT" = "blue" ] && echo "green" || echo "blue")
                    echo "Live: \$LIVE_SLOT → Deploying to: \$NEW_SLOT"

                    echo "--- Applying staging manifests ---"
                    sed "s|image: attendance:.*|image: ${env.DOCKER_IMAGE_RESOLVED}|g" \
                        ${K8S_STAGING} | kubectl apply -f -

                    kubectl rollout status deployment/attendance-\$NEW_SLOT \
                        -n staging --timeout=180s
                    echo "Staging rollout complete ✅"
                """
                script {
                    def newSlot = sh(
                        script: """LIVE=\$(kubectl get service attendance -n staging \
                            -o jsonpath='{.spec.selector.slot}' 2>/dev/null || echo 'blue')
                            [ "\$LIVE" = "blue" ] && echo "green" || echo "blue" """,
                        returnStdout: true
                    ).trim()

                    def stagingPod = sh(
                        script: """kubectl get pods -n staging \
                            -l app=attendance,slot=${newSlot} \
                            -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || echo ''""",
                        returnStdout: true
                    ).trim()

                    if (!stagingPod) {
                        sh "kubectl rollout undo deployment/attendance-${newSlot} -n staging || true"
                        error("Staging health check failed: no pod found")
                    }

                    def stagingHealthy = false
                    for (int i = 1; i <= env.HEALTH_CHECK_RETRIES.toInteger(); i++) {
                        def status = sh(
                            script: """kubectl exec -n staging ${stagingPod} \
                                -- curl -s -o /dev/null -w "%{http_code}" \
                                http://localhost:${env.HEALTH_PORT}/${SERVICE}/healthz \
                                2>/dev/null || echo '000'""",
                            returnStdout: true
                        ).trim()
                        echo "Staging health attempt ${i}/${env.HEALTH_CHECK_RETRIES}: HTTP ${status}"
                        if (status == '200') { stagingHealthy = true; break }
                        sleep(env.HEALTH_CHECK_INTERVAL.toInteger())
                    }

                    if (!stagingHealthy) {
                        sh """
                            kubectl rollout undo deployment/attendance-${newSlot} -n staging
                            kubectl rollout status deployment/attendance-${newSlot} \
                                -n staging --timeout=120s
                        """
                        def notifier = new NotificationManager(this)
                        def details  = getBuildDetails(this)
                        details.changes = details.changes + " | Staging ROLLED BACK ❌"
                        notifier.notifyAll('FAILURE', details)
                        error("Staging deployment rolled back ❌")
                    }

                    sh """
                        kubectl patch service attendance -n staging \
                            -p '{"spec":{"selector":{"slot":"${newSlot}"}}}'
                        echo "Staging traffic switched to ${newSlot} ✅"
                    """

                    def notifier = new NotificationManager(this)
                    def details  = getBuildDetails(this)
                    details.changes = details.changes + " | Staging deploy SUCCESS ✅"
                    notifier.notifyAll('SUCCESS', details)
                }
            }
        }

        // ── STAGE 12: APPROVAL FOR PRODUCTION ──────────────────
        stage('Approval: Blue-Green Deploy to Prod') {
            when {
                expression { return params.RUN_DEPLOYMENT == true }
            }
            steps {
                script {
                    milestone(3)
                    def notifier = new NotificationManager(this)
                    def details  = getBuildDetails(this)
                    details.changes = details.changes + " | Waiting for PROD approval ⏳"
                    notifier.notifyAll('UNSTABLE', details)
                    echo "Waiting for Prod approval (timeout: ${params.PROD_APPROVAL_TIMEOUT}m)"
                }
                timeout(time: params.PROD_APPROVAL_TIMEOUT.toInteger(), unit: 'MINUTES') {
                    input(
                        message: "Blue-Green deploy ${params.SERVICE} v${params.VERSION} to PRODUCTION?",
                        ok: 'Yes, Go Live on Production',
                        submitter: 'admin,devops-lead',
                        submitterParameter: 'PROD_APPROVER'
                    )
                }
                script {
                    echo "Production approved ✅  Approver: ${env.PROD_APPROVER ?: 'unknown'}"
                }
            }
        }

        // ── STAGE 13: BLUE-GREEN DEPLOY TO PROD ────────────────
        // Uses: Microservices-projects/kubernetes/prod/attendance-k8s.yaml
        // Strategy:
        //  1. Detect live slot from Service selector
        //  2. Apply prod YAML with updated image (both slots get new image)
        //  3. Health check the INACTIVE slot
        //  4. PASS  → patch Service selector → cutover
        //             scale old slot to 1 (hot standby)
        //  5. FAIL  → rollback inactive slot, live slot untouched
        stage('Blue-Green Deploy to Prod') {
            when {
                expression { return params.RUN_DEPLOYMENT == true }
            }
            steps {
                script {
                    echo "══════════════════════════════════════════════════"
                    echo " BLUE-GREEN DEPLOY: ${SERVICE} v${VERSION} → PROD"
                    echo "══════════════════════════════════════════════════"

                    // Step 1: Detect live slot
                    def liveSlot = sh(
                        script: """kubectl get service attendance -n prod \
                            -o jsonpath='{.spec.selector.slot}' 2>/dev/null || echo 'blue'""",
                        returnStdout: true
                    ).trim()
                    if (!liveSlot) { liveSlot = 'blue' }
                    def newSlot = (liveSlot == 'blue') ? 'green' : 'blue'

                    echo "Current LIVE slot : ${liveSlot}"
                    echo "Deploying to slot : ${newSlot}"
                    env.LIVE_SLOT = liveSlot
                    env.NEW_SLOT  = newSlot

                    // Step 2: Apply prod YAML with updated image
                    sh """
                        echo "--- Applying prod manifests with image: ${env.DOCKER_IMAGE_RESOLVED} ---"
                        sed "s|image: attendance:.*|image: ${env.DOCKER_IMAGE_RESOLVED}|g" \
                            ${K8S_PROD} | kubectl apply -f -

                        echo "--- Waiting for ${newSlot} slot rollout ---"
                        kubectl rollout status deployment/attendance-${newSlot} \
                            -n prod --timeout=300s
                        echo "${newSlot} slot ready ✅"
                    """

                    // Step 3: Health check inactive (new) slot
                    def newPod = sh(
                        script: """kubectl get pods -n prod \
                            -l app=attendance,slot=${newSlot} \
                            -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || echo ''""",
                        returnStdout: true
                    ).trim()

                    if (!newPod) {
                        sh """
                            kubectl rollout undo deployment/attendance-${newSlot} -n prod || true
                        """
                        def notifier = new NotificationManager(this)
                        def details  = getBuildDetails(this)
                        details.changes = details.changes +
                            " | PROD ABORTED — no pod in ${newSlot} (${liveSlot} still live) ❌"
                        notifier.notifyAll('FAILURE', details)
                        error("Blue-Green aborted: no pod in ${newSlot}. ${liveSlot} still serving ✅")
                    }

                    def bgHealthy = false
                    for (int i = 1; i <= env.HEALTH_CHECK_RETRIES.toInteger(); i++) {
                        def status = sh(
                            script: """kubectl exec -n prod ${newPod} \
                                -- curl -s -o /dev/null -w "%{http_code}" \
                                http://localhost:${env.HEALTH_PORT}/${SERVICE}/healthz \
                                2>/dev/null || echo '000'""",
                            returnStdout: true
                        ).trim()
                        echo "Prod ${newSlot} health attempt ${i}/${env.HEALTH_CHECK_RETRIES}: HTTP ${status}"
                        if (status == '200') { bgHealthy = true; break }
                        sleep(env.HEALTH_CHECK_INTERVAL.toInteger())
                    }

                    if (!bgHealthy) {
                        // Step 5: FAIL — rollback new slot, live slot untouched
                        echo "❌ NEW SLOT UNHEALTHY — ROLLING BACK"
                        echo "   Service selector NOT changed — ${liveSlot} still live ✅"
                        sh """
                            kubectl scale deployment/attendance-${newSlot} --replicas=0 -n prod
                            kubectl rollout undo deployment/attendance-${newSlot} -n prod
                        """
                        def notifier = new NotificationManager(this)
                        def details  = getBuildDetails(this)
                        details.changes = details.changes +
                            " | PROD ROLLED BACK — ${liveSlot} still live ❌"
                        notifier.notifyAll('FAILURE', details)
                        error("Prod Blue-Green failed: ${newSlot} unhealthy. ${liveSlot} still live ✅")
                    }

                    // Step 4: PASS — cutover traffic to new slot
                    sh """
                        kubectl patch service attendance -n prod \
                            -p '{"spec":{"selector":{"slot":"${newSlot}"}}}'
                        echo "Traffic switched → ${newSlot} (100%) ✅"

                        # Keep old slot at 1 replica as hot standby
                        kubectl scale deployment/attendance-${liveSlot} --replicas=1 -n prod
                        echo "${liveSlot} scaled to 1 (hot standby for instant rollback)"
                    """

                    echo "══════════════════════════════════════════════════"
                    echo " ✅ Blue-Green cutover complete!"
                    echo "    LIVE    : ${newSlot} (100% traffic)"
                    echo "    STANDBY : ${liveSlot} (1 replica)"
                    echo "══════════════════════════════════════════════════"

                    def notifier = new NotificationManager(this)
                    def details  = getBuildDetails(this)
                    details.changes = details.changes + " | PROD Blue-Green SUCCESS — ${newSlot} live ✅"
                    notifier.notifyAll('SUCCESS', details)
                }
            }
        }

    } // end stages

    // ═══════════════════════════════════════════════════════════
    //  POST BLOCKS
    // ═══════════════════════════════════════════════════════════
    post {
        always {
            script {
                echo "Pipeline finished — Status: ${currentBuild.currentResult}"
            }
            archiveArtifacts artifacts: "${REPORT_DIR}/**",
                             allowEmptyArchive: true
        }
        success {
            script {
                def notifier = new NotificationManager(this)
                def details  = getBuildDetails(this)
                details.changes = details.changes + " | ALL PASSED ✅"
                notifier.notifyAll('SUCCESS', details)
                uploadPdfToSlack("✅ Test Report: ${SERVICE} v${VERSION} — ALL TESTS PASSED")
            }
        }
        failure {
            script {
                def notifier = new NotificationManager(this)
                def details  = getBuildDetails(this)
                details.changes = details.changes + " | FAILED ❌"
                notifier.notifyAll('FAILURE', details)
                uploadPdfToSlack("❌ Test Report: ${SERVICE} v${VERSION} — FAILED")
            }
        }
        unstable {
            script {
                def notifier = new NotificationManager(this)
                def details  = getBuildDetails(this)
                details.changes = details.changes + " | UNSTABLE ⚠️"
                notifier.notifyAll('UNSTABLE', details)
                uploadPdfToSlack("⚠️ Test Report: ${SERVICE} v${VERSION} — UNSTABLE")
            }
        }
        cleanup {
            cleanWs()
        }
    }
}

// ═══════════════════════════════════════════════════════════════
//  HELPER — Upload PDF to Slack
// ═══════════════════════════════════════════════════════════════
def uploadPdfToSlack(String comment) {
    try {
        withCredentials([string(credentialsId: env.SLACK_CRED_ID, variable: 'SLACK_TOKEN')]) {
            sh """
                if [ -f ${env.REPORT_DIR}/test-report.pdf ]; then
                    RESPONSE=\$(curl -s \
                        -F file=@${env.REPORT_DIR}/test-report.pdf \
                        -F channels=${env.SLACK_CHANNEL} \
                        -F initial_comment="${comment}" \
                        -H "Authorization: Bearer \$SLACK_TOKEN" \
                        https://slack.com/api/files.upload)
                    echo "Slack upload: \$RESPONSE"
                    echo "\$RESPONSE" | python3 -c "
import sys, json
r = json.load(sys.stdin)
print('PDF uploaded to Slack ✅' if r.get('ok') else f'Warning: {r.get(\\\"error\\\",\\\"unknown\\\")}')
"
                else
                    echo "PDF not found — skipping Slack upload"
                fi
            """
        }
    } catch (Exception e) {
        echo "WARNING: Slack PDF upload failed: ${e.message}"
    }
}

// ═══════════════════════════════════════════════════════════════
//  HELPER — Build Details Map
// ═══════════════════════════════════════════════════════════════
def getBuildDetails(def ctx) {
    String changes = 'No changes'
    try {
        changes = ctx.sh(
            script: "git log -1 --pretty=format:'%s by %an'",
            returnStdout: true
        ).trim()
    } catch (Exception e) {
        changes = 'Could not fetch changes'
    }

    String buildUrl    = ctx.env.BUILD_URL ?: "${ctx.env.JENKINS_URL ?: 'http://localhost:8080'}job/${ctx.env.JOB_NAME}/${ctx.env.BUILD_NUMBER}/"
    String testsUrl    = "${buildUrl}testReport/"
    String coverageUrl = "${buildUrl}coverage/"
    String pdfUrl      = "${buildUrl}artifact/test-reports/test-report.pdf"

    return [
        jobName     : ctx.env.JOB_NAME       ?: 'Unknown Job',
        buildNumber : ctx.env.BUILD_NUMBER   ?: '0',
        buildUrl    : buildUrl,
        testsUrl    : testsUrl,
        coverageUrl : coverageUrl,
        artifactsUrl: pdfUrl,
        branch      : ctx.env.GIT_BRANCH     ?: 'master',
        service     : ctx.params.SERVICE     ?: 'unknown',
        version     : ctx.params.VERSION     ?: '0.0.0',
        environment : ctx.params.ENVIRONMENT ?: 'staging',
        duration    : ctx.currentBuild.durationString ?: 'N/A',
        changes     : changes,
        recipients  : ctx.params.RECIPIENTS  ?: 'YOUR_EMAIL@gmail.com'
    ]
}
