@Library('jenkins-shared-library@master') _

import org.example.NotificationManager

// ═══════════════════════════════════════════════════════════════
//  COMPLETE TESTING PIPELINE — PRODUCTION READY
//  Unit → Coverage → Parallel(Integration + Lint) → E2E
//  Reports: JUnit + Coverage + PDF → Slack (with Quick Links)
// ═══════════════════════════════════════════════════════════════

pipeline {
    agent any

    parameters {
        choice(
            name: 'SERVICE',
            choices: ['attendance', 'employee', 'salary', 'frontend', 'notification'],
            description: 'Microservice to test'
        )
        string(
            name: 'VERSION',
            defaultValue: '1.0.0',
            description: 'Version under test (semver e.g. 1.0.0)'
        )
        choice(
            name: 'TEST_SCOPE',
            choices: ['all', 'unit', 'integration', 'e2e'],
            description: 'Which tests to run'
        )
        choice(
            name: 'ENVIRONMENT',
            choices: ['staging', 'dev', 'prod'],
            description: 'Target environment for E2E tests'
        )
        string(
            name: 'RECIPIENTS',
            defaultValue: 'YOUR_EMAIL@gmail.com',
            description: 'Email recipients (comma separated)'
        )
        booleanParam(
            name: 'FAIL_ON_COVERAGE',
            defaultValue: true,
            description: 'Fail build if coverage below threshold?'
        )
    }

    environment {
        SERVICE       = "${params.SERVICE}"
        VERSION       = "${params.VERSION}"
        ENVIRONMENT   = "${params.ENVIRONMENT}"
        COVERAGE_MIN  = '60'
        REPORT_DIR    = 'test-reports'
        COVERAGE_DIR  = 'coverage-reports'
        JUNIT_PATTERN = "${REPORT_DIR}/**/*.xml"
        KUBECONFIG    = '/var/lib/jenkins/.kube/config'
        SLACK_CHANNEL = '#jenkins-notifications'
        SLACK_CRED_ID = 'slackaditya'
    }

    stages {

        // ── STAGE 1: SETUP ──────────────────────────────────────
        stage('Setup') {
            steps {
                script {
                    echo "═══════════════════════════════════════"
                    echo " TEST PIPELINE: ${SERVICE} v${VERSION}"
                    echo " Scope     : ${params.TEST_SCOPE}"
                    echo " Environment: ${ENVIRONMENT}"
                    echo "═══════════════════════════════════════"

                    // FIX 1: Send BOTH Slack AND Email on STARTED
                    def notifier = new NotificationManager(this)
                    def details  = getBuildDetails(this)
                    notifier.sendSlack('STARTED', details)
                    notifier.sendEmail('STARTED', details)

                    sh """
                        mkdir -p ${REPORT_DIR}/unit
                        mkdir -p ${REPORT_DIR}/integration
                        mkdir -p ${REPORT_DIR}/e2e
                        mkdir -p ${REPORT_DIR}/lint
                        mkdir -p ${COVERAGE_DIR}
                    """
                }
            }
        }

        // ── STAGE 2: UNIT TESTS ─────────────────────────────────
        stage('Unit Tests') {
            when {
                expression { return params.TEST_SCOPE in ['all', 'unit'] }
            }
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh """
                        cd Microservices-projects/${SERVICE}

                        # ── Python services ──────────────────────
                        if [ -f requirements.txt ]; then
                            pip3 install -r requirements.txt \
                                pytest pytest-cov pytest-html -q

                            python3 -m pytest \
                                --junitxml=../../${REPORT_DIR}/unit/unit-results.xml \
                                --cov=. \
                                --cov-report=xml:../../${COVERAGE_DIR}/coverage.xml \
                                --cov-report=html:../../${COVERAGE_DIR}/html \
                                --cov-report=term-missing \
                                --cov-fail-under=${COVERAGE_MIN} \
                                -v test_*.py \
                                2>&1 | tee ../../${REPORT_DIR}/unit/unit.log

                        # ── Node/Frontend services ───────────────
                        elif [ -f package.json ]; then
                            npm install
                            npm test -- \
                                --reporter junit \
                                --reporter-options output=../../${REPORT_DIR}/unit/unit-results.xml \
                                2>&1 | tee ../../${REPORT_DIR}/unit/unit.log

                        # ── Java services ────────────────────────
                        elif [ -f pom.xml ]; then
                            mvn test \
                                -Dsurefire.reportsDirectory=../../${REPORT_DIR}/unit \
                                jacoco:report \
                                2>&1 | tee ../../${REPORT_DIR}/unit/unit.log

                        else
                            echo "No test framework detected — skipping"
                        fi
                    """
                }
            }
            post {
                always {
                    junit testResults: "${REPORT_DIR}/unit/unit-results.xml",
                          allowEmptyResults: true
                    archiveArtifacts artifacts: "${REPORT_DIR}/unit/**",
                                     allowEmptyArchive: true
                }
            }
        }

        // ── STAGE 3: COVERAGE CHECK ─────────────────────────────
        stage('Coverage Check') {
            when {
                expression { return params.TEST_SCOPE in ['all', 'unit'] }
            }
            steps {
                script {
                    echo "=== COVERAGE CHECK (min: ${COVERAGE_MIN}%) ==="
                }
                catchError(
                    buildResult: params.FAIL_ON_COVERAGE ? 'FAILURE' : 'UNSTABLE',
                    stageResult: 'FAILURE'
                ) {
                    sh """
                        if [ -f ${COVERAGE_DIR}/coverage.xml ]; then
                            COVERAGE=\$(python3 -c "
import xml.etree.ElementTree as ET
root = ET.parse('${COVERAGE_DIR}/coverage.xml').getroot()
rate = float(root.get('line-rate', 0)) * 100
print(f'{rate:.1f}')
")
                            echo "Coverage: \${COVERAGE}%"
                            echo "\${COVERAGE}" > ${COVERAGE_DIR}/coverage-percent.txt

                            python3 -c "
rate = float('\${COVERAGE}')
threshold = ${COVERAGE_MIN}
if rate < threshold:
    print(f'COVERAGE FAILED: {rate:.1f}% < {threshold}%')
    exit(1)
print(f'COVERAGE PASSED: {rate:.1f}% >= {threshold}%')
"
                        else
                            echo "No coverage.xml found — skipping coverage check"
                        fi
                    """
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${COVERAGE_DIR}/**",
                                     allowEmptyArchive: true
                }
            }
        }

        // ── STAGE 4: PARALLEL — INTEGRATION + LINT ─────────────
        stage('Parallel: Integration + Lint') {
            when {
                expression { return params.TEST_SCOPE in ['all', 'integration'] }
            }
            parallel {

                // ── 4a: INTEGRATION TESTS ────────────────────────
                stage('Integration Tests') {
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh """
                                cd Microservices-projects/${SERVICE}

                                if [ -f requirements.txt ]; then
                                    python3 -m pytest \
                                        --junitxml=../../${REPORT_DIR}/integration/integration-results.xml \
                                        -v -m integration \
                                        test_*.py \
                                        2>&1 | tee ../../${REPORT_DIR}/integration/integration.log \
                                        || echo "Integration tests completed"
                                elif [ -f package.json ]; then
                                    npm run test:integration \
                                        2>&1 | tee ../../${REPORT_DIR}/integration/integration.log \
                                        || echo "Integration tests completed"
                                else
                                    echo "No integration tests found"
                                fi
                            """
                        }
                    }
                    post {
                        always {
                            junit testResults: "${REPORT_DIR}/integration/integration-results.xml",
                                  allowEmptyResults: true
                            archiveArtifacts artifacts: "${REPORT_DIR}/integration/**",
                                             allowEmptyArchive: true
                        }
                    }
                }

                // ── 4b: LINT & STATIC ANALYSIS ───────────────────
                stage('Lint & Static Analysis') {
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh """
                                cd Microservices-projects/${SERVICE}

                                if [ -f requirements.txt ]; then
                                    pip3 install flake8 pylint -q

                                    echo "--- flake8 ---"
                                    flake8 . \
                                        --max-line-length=120 \
                                        --exclude=.git,__pycache__,venv \
                                        > ../../${REPORT_DIR}/lint/flake8.log 2>&1 || true
                                    cat ../../${REPORT_DIR}/lint/flake8.log

                                    echo "--- pylint ---"
                                    pylint *.py \
                                        --fail-under=7.0 \
                                        > ../../${REPORT_DIR}/lint/pylint.log 2>&1 \
                                        || echo "Pylint score below threshold"
                                    cat ../../${REPORT_DIR}/lint/pylint.log

                                elif [ -f package.json ]; then
                                    npm run lint \
                                        > ../../${REPORT_DIR}/lint/eslint.log 2>&1 || true
                                fi
                            """
                        }
                    }
                    post {
                        always {
                            archiveArtifacts artifacts: "${REPORT_DIR}/lint/**",
                                             allowEmptyArchive: true
                        }
                    }
                }

            } // end parallel
        }

        // ── STAGE 5: E2E TESTS ──────────────────────────────────
        stage('E2E Tests') {
            when {
                expression { return params.TEST_SCOPE in ['all', 'e2e'] }
            }
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh """
                        mkdir -p ${REPORT_DIR}/e2e

                        # Determine environments to test
                        case "${ENVIRONMENT}" in
                            dev)     ENVS="dev" ;;
                            staging) ENVS="staging" ;;
                            prod)    ENVS="staging prod" ;;
                            *)       ENVS="staging" ;;
                        esac

                        echo "E2E environments: \$ENVS"
                        TOTAL=0; PASSED=0; FAILED=0; XML_CASES=""

                        for ENV in \$ENVS; do
                            echo "=== E2E: ${SERVICE} in \$ENV ==="

                            # Find pod (blue → green → any)
                            POD=\$(kubectl get pods -n \$ENV \
                                -l app=${SERVICE},slot=blue \
                                -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || echo "")

                            if [ -z "\$POD" ]; then
                                POD=\$(kubectl get pods -n \$ENV \
                                    -l app=${SERVICE},slot=green \
                                    -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || echo "")
                            fi

                            if [ -z "\$POD" ]; then
                                POD=\$(kubectl get pods -n \$ENV \
                                    -l app=${SERVICE} \
                                    -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || echo "")
                            fi

                            if [ -z "\$POD" ]; then
                                echo "No pod found in \$ENV — skipping"
                                TOTAL=\$((TOTAL+1))
                                XML_CASES="\$XML_CASES
  <testcase name='e2e_health_\$ENV' classname='e2e.\$ENV'>
    <skipped>No pod found in \$ENV</skipped>
  </testcase>"
                                continue
                            fi

                            echo "Pod: \$POD"

                            # Health check with 5 retries
                            STATUS="000"
                            for i in 1 2 3 4 5; do
                                STATUS=\$(kubectl exec -n \$ENV \$POD \
                                    -- curl -s -o /dev/null \
                                    -w "%{http_code}" \
                                    http://localhost:8081/${SERVICE}/healthz \
                                    2>/dev/null || echo "000")
                                echo "Attempt \$i [\$ENV]: HTTP \$STATUS"
                                if [ "\$STATUS" = "200" ]; then break; fi
                                sleep 5
                            done

                            TOTAL=\$((TOTAL+1))
                            if [ "\$STATUS" = "200" ]; then
                                PASSED=\$((PASSED+1))
                                echo "E2E PASSED: \$ENV ✅"
                                XML_CASES="\$XML_CASES
  <testcase name='e2e_health_\$ENV' classname='e2e.\$ENV'/>"
                            else
                                FAILED=\$((FAILED+1))
                                echo "E2E FAILED: \$ENV ❌ (HTTP \$STATUS)"
                                XML_CASES="\$XML_CASES
  <testcase name='e2e_health_\$ENV' classname='e2e.\$ENV'>
    <failure message='HTTP \$STATUS'>Health check failed: HTTP \$STATUS in \$ENV</failure>
  </testcase>"
                            fi
                        done

                        cat > ${REPORT_DIR}/e2e/e2e-results.xml << XMLEOF
<?xml version="1.0" encoding="UTF-8"?>
<testsuite name="E2E-${SERVICE}" tests="\$TOTAL" failures="\$FAILED" skipped="0">
\$XML_CASES
</testsuite>
XMLEOF

                        echo "E2E Summary → Total: \$TOTAL | Passed: \$PASSED | Failed: \$FAILED"
                        if [ "\$FAILED" -gt "0" ]; then
                            echo "E2E FAILED in \$FAILED environment(s)"
                            exit 1
                        fi
                        echo "All E2E tests PASSED ✅"
                    """
                }
            }
            post {
                always {
                    junit testResults: "${REPORT_DIR}/e2e/e2e-results.xml",
                          allowEmptyResults: true
                    archiveArtifacts artifacts: "${REPORT_DIR}/e2e/**",
                                     allowEmptyArchive: true
                }
            }
        }

        // ── STAGE 6: GENERATE PDF REPORT ───────────────────────
        stage('Generate PDF Report') {
            steps {
                sh """
                    pip3 install fpdf2 -q

                    python3 << 'PYEOF'
from fpdf import FPDF
import xml.etree.ElementTree as ET
import os, datetime

class TestReport(FPDF):
    def header(self):
        self.set_font('Helvetica', 'B', 16)
        self.set_fill_color(41, 128, 185)
        self.set_text_color(255, 255, 255)
        self.cell(0, 12, 'Jenkins Test Report', new_x='LMARGIN', new_y='NEXT', fill=True, align='C')
        self.set_text_color(0, 0, 0)
        self.ln(4)

    def footer(self):
        self.set_y(-15)
        self.set_font('Helvetica', 'I', 8)
        self.set_text_color(128, 128, 128)
        self.cell(0, 10,
            f'Page {self.page_no()} | Generated: {datetime.datetime.now().strftime("%Y-%m-%d %H:%M")}',
            align='C')

def parse_junit(path):
    if not os.path.exists(path):
        return {'tests':0,'failures':0,'errors':0,'skipped':0,'cases':[]}
    try:
        root = ET.parse(path).getroot()
        suite = root if root.tag == 'testsuite' else (root.find('testsuite') or root)
        cases = []
        for tc in suite.findall('testcase'):
            st = 'PASS'
            if tc.find('failure') is not None: st = 'FAIL'
            elif tc.find('error') is not None: st = 'ERROR'
            elif tc.find('skipped') is not None: st = 'SKIP'
            cases.append({'name': tc.get('name','?'), 'status': st, 'time': tc.get('time','0')})
        return {
            'tests'   : int(suite.get('tests', len(cases))),
            'failures': int(suite.get('failures', 0)),
            'errors'  : int(suite.get('errors', 0)),
            'skipped' : int(suite.get('skipped', 0)),
            'cases'   : cases
        }
    except:
        return {'tests':0,'failures':0,'errors':0,'skipped':0,'cases':[]}

def get_coverage():
    f = '${COVERAGE_DIR}/coverage-percent.txt'
    try:
        return float(open(f).read().strip()) if os.path.exists(f) else None
    except:
        return None

unit = parse_junit('${REPORT_DIR}/unit/unit-results.xml')
intg = parse_junit('${REPORT_DIR}/integration/integration-results.xml')
e2e  = parse_junit('${REPORT_DIR}/e2e/e2e-results.xml')
cov  = get_coverage()

total_tests    = unit['tests'] + intg['tests'] + e2e['tests']
total_failures = unit['failures'] + intg['failures'] + e2e['failures']
total_passed   = total_tests - total_failures

pdf = TestReport()
pdf.set_auto_page_break(auto=True, margin=15)
pdf.add_page()

# Build Info
pdf.set_font('Helvetica', 'B', 13)
pdf.set_fill_color(236, 240, 241)
pdf.cell(0, 9, 'Build Information', new_x='LMARGIN', new_y='NEXT', fill=True)
pdf.ln(2)
for k, v in [
    ('Service',     '${SERVICE}'),
    ('Version',     '${VERSION}'),
    ('Environment', '${ENVIRONMENT}'),
    ('Build No.',   '${BUILD_NUMBER}'),
    ('Branch',      '${GIT_BRANCH}' or 'master'),
    ('Timestamp',   datetime.datetime.now().strftime('%Y-%m-%d %H:%M')),
    ('Test Scope',  '${params.TEST_SCOPE}'),
]:
    pdf.set_font('Helvetica', 'B', 10)
    pdf.cell(45, 7, k + ':')
    pdf.set_font('Helvetica', '', 10)
    pdf.cell(0, 7, str(v), new_x='LMARGIN', new_y='NEXT')
pdf.ln(4)

# Test Summary Table
pdf.set_font('Helvetica', 'B', 13)
pdf.set_fill_color(236, 240, 241)
pdf.cell(0, 9, 'Test Summary', new_x='LMARGIN', new_y='NEXT', fill=True)
pdf.ln(2)

pdf.set_font('Helvetica', 'B', 10)
pdf.set_fill_color(41, 128, 185)
pdf.set_text_color(255, 255, 255)
for col, w in [('Suite',50),('Total',25),('Passed',25),('Failed',25),('Skip',25),('Result',40)]:
    pdf.cell(w, 8, col, border=1, fill=True, align='C')
pdf.ln()
pdf.set_text_color(0, 0, 0)

def suite_row(pdf, name, data):
    passed = data['tests'] - data['failures'] - data.get('errors',0) - data.get('skipped',0)
    ok     = data['failures'] == 0 and data['errors'] == 0
    c      = (39,174,96) if ok else (231,76,60)
    pdf.set_font('Helvetica', '', 10)
    pdf.set_fill_color(249, 249, 249)
    pdf.cell(50, 7, name, border=1, fill=True)
    pdf.cell(25, 7, str(data['tests']),         border=1, align='C', fill=True)
    pdf.cell(25, 7, str(passed),                border=1, align='C', fill=True)
    pdf.cell(25, 7, str(data['failures']),      border=1, align='C', fill=True)
    pdf.cell(25, 7, str(data.get('skipped',0)), border=1, align='C', fill=True)
    pdf.set_fill_color(*c); pdf.set_text_color(255,255,255)
    pdf.cell(40, 7, 'PASS' if ok else 'FAIL', border=1, align='C', fill=True)
    pdf.set_text_color(0,0,0); pdf.ln()

suite_row(pdf, 'Unit Tests',        unit)
suite_row(pdf, 'Integration Tests', intg)
suite_row(pdf, 'E2E Tests',         e2e)

pdf.set_font('Helvetica', 'B', 10)
pdf.set_fill_color(41, 128, 185); pdf.set_text_color(255,255,255)
ok = total_failures == 0
pdf.cell(50, 8, 'TOTAL',             border=1, fill=True)
pdf.cell(25, 8, str(total_tests),    border=1, align='C', fill=True)
pdf.cell(25, 8, str(total_passed),   border=1, align='C', fill=True)
pdf.cell(25, 8, str(total_failures), border=1, align='C', fill=True)
pdf.cell(25, 8, '-',                 border=1, align='C', fill=True)
pdf.cell(40, 8, 'PASS' if ok else 'FAIL', border=1, align='C', fill=True)
pdf.set_text_color(0,0,0); pdf.ln(6)

# Coverage
pdf.set_font('Helvetica', 'B', 13)
pdf.set_fill_color(236, 240, 241)
pdf.cell(0, 9, 'Code Coverage', new_x='LMARGIN', new_y='NEXT', fill=True)
pdf.ln(2)
if cov is not None:
    c = (39,174,96) if cov >= 60 else (231,76,60)
    pdf.set_font('Helvetica', 'B', 32)
    pdf.set_text_color(*c)
    pdf.cell(0, 14, f'{cov:.1f}%', new_x='LMARGIN', new_y='NEXT', align='C')
    pdf.set_text_color(0,0,0)
    pdf.set_font('Helvetica', '', 10)
    pdf.cell(0, 7, f'Threshold: 60% | {"PASSED" if cov>=60 else "FAILED"}',
             new_x='LMARGIN', new_y='NEXT', align='C')
    pdf.ln(2)
    pdf.set_fill_color(220,220,220)
    pdf.cell(170, 8, '', border=0, fill=True); pdf.ln()
    pdf.set_xy(pdf.get_x(), pdf.get_y()-8)
    pdf.set_fill_color(*c)
    pdf.cell(min(170*cov/100, 170), 8, '', border=0, fill=True); pdf.ln(6)
else:
    pdf.set_font('Helvetica','I',10)
    pdf.cell(0,7,'Coverage data not available', new_x='LMARGIN', new_y='NEXT')
pdf.ln(4)

# Test Case Details
for sname, sdata in [('Unit Tests',unit),('Integration Tests',intg),('E2E Tests',e2e)]:
    if not sdata['cases']: continue
    pdf.set_font('Helvetica','B',12)
    pdf.set_fill_color(52,73,94); pdf.set_text_color(255,255,255)
    pdf.cell(0,8,f'  {sname}', new_x='LMARGIN', new_y='NEXT', fill=True)
    pdf.set_text_color(0,0,0); pdf.ln(1)
    pdf.set_font('Helvetica','B',9)
    pdf.set_fill_color(189,195,199)
    pdf.cell(115,7,'Test Name',border=1,fill=True)
    pdf.cell(30, 7,'Status',  border=1,align='C',fill=True)
    pdf.cell(25, 7,'Time(s)', border=1,align='C',fill=True); pdf.ln()
    sc = {'PASS':(39,174,96),'FAIL':(231,76,60),'ERROR':(231,76,60),'SKIP':(243,156,18)}
    for i,case in enumerate(sdata['cases']):
        bg = (249,249,249) if i%2==0 else (255,255,255)
        pdf.set_fill_color(*bg); pdf.set_font('Helvetica','',9)
        nm = case['name'][:60]+'...' if len(case['name'])>60 else case['name']
        pdf.cell(115,6,nm,border=1,fill=True)
        c2 = sc.get(case['status'],(128,128,128))
        pdf.set_fill_color(*c2); pdf.set_text_color(255,255,255)
        pdf.cell(30,6,case['status'],border=1,align='C',fill=True)
        pdf.set_text_color(0,0,0); pdf.set_fill_color(*bg)
        pdf.cell(25,6,case['time'],border=1,align='C',fill=True); pdf.ln()
    pdf.ln(4)

os.makedirs('${REPORT_DIR}', exist_ok=True)
pdf.output('${REPORT_DIR}/test-report.pdf')
print('PDF generated: ${REPORT_DIR}/test-report.pdf')
PYEOF
                """
            }
            post {
                always {
                    archiveArtifacts artifacts: "${REPORT_DIR}/test-report.pdf",
                                     allowEmptyArchive: true
                }
            }
        }

        // ── STAGE 7: PUBLISH REPORTS ────────────────────────────
        stage('Publish Reports') {
            steps {
                script {
                    echo "=== PUBLISHING ALL REPORTS TO JENKINS ==="
                    junit testResults: "${JUNIT_PATTERN}",
                          allowEmptyResults: true
                    echo "Reports published ✅"
                }
            }
        }

    } // end stages

    // ═══════════════════════════════════════════════════════════
    //  POST BLOCKS
    // ═══════════════════════════════════════════════════════════
    post {

        always {
            script {
                echo "Pipeline finished — Status: ${currentBuild.currentResult}"
            }
            archiveArtifacts artifacts: "${REPORT_DIR}/**",
                             allowEmptyArchive: true
        }

        success {
            script {
                def notifier = new NotificationManager(this)
                def details  = getBuildDetails(this)
                details.changes = details.changes + " | ALL TESTS PASSED ✅"
                notifier.sendSlack('SUCCESS', details)
                uploadPdfToSlack("✅ Test Report: ${SERVICE} v${VERSION} — ALL TESTS PASSED")
                notifier.sendEmail('SUCCESS', details)
                notifier.sendTeams('SUCCESS', details)
            }
        }

        failure {
            script {
                def notifier = new NotificationManager(this)
                def details  = getBuildDetails(this)
                details.changes = details.changes + " | TESTS FAILED ❌"
                notifier.sendSlack('FAILURE', details)
                uploadPdfToSlack("❌ Test Report: ${SERVICE} v${VERSION} — FAILED")
                notifier.sendEmail('FAILURE', details)
                notifier.sendTeams('FAILURE', details)
            }
        }

        unstable {
            script {
                def notifier = new NotificationManager(this)
                def details  = getBuildDetails(this)
                details.changes = details.changes + " | UNSTABLE ⚠️"
                notifier.sendSlack('UNSTABLE', details)
                uploadPdfToSlack("⚠️ Test Report: ${SERVICE} v${VERSION} — UNSTABLE")
                notifier.sendEmail('UNSTABLE', details)
                notifier.sendTeams('UNSTABLE', details)
            }
        }

        cleanup {
            cleanWs()
        }
    }
}

// ═══════════════════════════════════════════════════════════════
//  HELPER — Upload PDF to Slack via curl
// ═══════════════════════════════════════════════════════════════
def uploadPdfToSlack(String comment) {
    try {
        withCredentials([string(credentialsId: env.SLACK_CRED_ID, variable: 'SLACK_TOKEN')]) {
            sh """
                if [ -f ${env.REPORT_DIR}/test-report.pdf ]; then
                    RESPONSE=\$(curl -s \
                        -F file=@${env.REPORT_DIR}/test-report.pdf \
                        -F channels=${env.SLACK_CHANNEL} \
                        -F initial_comment="${comment}" \
                        -H "Authorization: Bearer \$SLACK_TOKEN" \
                        https://slack.com/api/files.upload)
                    echo "Slack upload: \$RESPONSE"
                    echo "\$RESPONSE" | python3 -c "
import sys, json
r = json.load(sys.stdin)
print('PDF uploaded to Slack ✅' if r.get('ok') else f'Warning: {r.get(\\\"error\\\",\\\"unknown\\\")}')
"
                else
                    echo "PDF not found — skipping Slack upload"
                fi
            """
        }
    } catch (Exception e) {
        echo "WARNING: Slack PDF upload failed: ${e.message}"
    }
}

// ═══════════════════════════════════════════════════════════════
//  HELPER — Build Details Map (with all Quick Link URLs)
//  FIX 2: Use JENKINS_URL as fallback so links are never localhost
// ═══════════════════════════════════════════════════════════════
def getBuildDetails(def ctx) {
    String changes = 'No changes'
    try {
        changes = ctx.sh(
            script: "git log -1 --pretty=format:'%s by %an'",
            returnStdout: true
        ).trim()
    } catch (Exception e) {
        changes = 'Could not fetch changes'
    }

    // FIX 2: Build a reliable URL — prefer BUILD_URL, fall back to JENKINS_URL + path
    String buildUrl = ctx.env.BUILD_URL
        ?: "${ctx.env.JENKINS_URL ?: 'http://localhost:8080'}job/${ctx.env.JOB_NAME}/${ctx.env.BUILD_NUMBER}/"

    // Construct all quick-link URLs from the resolved buildUrl
    String testsUrl    = "${buildUrl}testReport/"
    String coverageUrl = "${buildUrl}coverage/"
    String pdfUrl      = "${buildUrl}artifact/test-reports/test-report.pdf"

    return [
        jobName     : ctx.env.JOB_NAME       ?: 'Unknown Job',
        buildNumber : ctx.env.BUILD_NUMBER   ?: '0',
        buildUrl    : buildUrl,
        testsUrl    : testsUrl,        // ← Quick Link: Test Results
        coverageUrl : coverageUrl,     // ← Quick Link: Coverage Report
        artifactsUrl: pdfUrl,          // ← Quick Link: Download PDF Report
        branch      : ctx.env.GIT_BRANCH     ?: 'master',
        service     : ctx.params.SERVICE     ?: 'unknown',
        version     : ctx.params.VERSION     ?: '0.0.0',
        environment : ctx.params.ENVIRONMENT ?: 'staging',
        duration    : ctx.currentBuild.durationString ?: 'N/A',
        changes     : changes,
        recipients  : ctx.params.RECIPIENTS  ?: 'YOUR_EMAIL@gmail.com'
    ]
}
